{
  "name": "lowmess",
  "version": "5.0.0",
  "type": "module",
  "description": "The website and portfolio of Alec Lomas",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
