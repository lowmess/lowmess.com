---
import { type HTMLAttributes } from "astro/types";

import Sphere from "~/components/Sphere.astro";
import Grid from "~/components/Grid.astro";

type Props = HTMLAttributes<"div">;

const { class: className, ...props } = Astro.props;
---

<div class:list={["container", className]} {...props}>
	<h1>my name is alec&nbsp;lomas, and i make websites.</h1>

	<Sphere class="sphere" />

	<Grid class="grid" cellWidth="3cqw" />

	<img class="marker" src="/assets/marker.png" alt="" />

	<img class="pen" src="/assets/pen_orange.png" alt="" />

	<div class="content">
		<p>
			For over a decade, I&apos;ve been designing for the web &amp; building the
			frontends that power those designs. TKTKTKTK
		</p>
	</div>
</div>

<style>
	/* TODO styles below 960px */
	.container {
		position: relative;
		container-type: inline-size;
		max-width: 1440px;
		padding-inline: var(--container-padding);
	}

	h1 {
		position: relative;
		left: 19cqw;
		width: 81cqw;
		font-size: var(--font-size-heading);
		line-height: calc(var(--font-size-heading) - var(--space-sm));
		margin-block-end: 0;
		z-index: 30;
		text-shadow: rgb(0, 0, 0, 0.25) 0 0 8px;
	}

	.sphere {
		position: absolute;
		top: 2cqw;
		left: 1cqw;
		z-index: 20;
		width: 33cqw;
		box-shadow: 8px 8px 32px -8px rgb(0, 0, 0, 0.5);
	}

	.grid {
		position: absolute;
		top: -2cqw;
		left: 16cqw;
		z-index: -1;
		width: 24cqw;
		aspect-ratio: 1 / 3;
	}

	.marker {
		position: absolute;
		top: -2cqw;
		left: -8cqw;
		z-index: -2;
		width: 60cqw;
		opacity: 0.5;
		pointer-events: none;
	}

	.pen {
		position: relative;
		left: 10cqw;
		width: 90cqw;
		pointer-events: none;
	}

	.content {
		position: relative;
		left: calc(40cqw + var(--space-lg));
		width: calc(60cqw - var(--space-lg));
		max-width: 55ch;
		margin-block-start: var(--space-lg);
	}
</style>
