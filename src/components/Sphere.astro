---
import { type HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"div">;

const { class: className, ...props } = Astro.props;
---

<div class:list={["sphere", className]} {...props}></div>

<style>
	.sphere {
		aspect-ratio: 1;
		background-color: var(--color-primary);
		border-radius: 100%;
		pointer-events: none;
	}

	.sphere::before,
	.sphere::after {
		content: "";
		display: block;
		position: absolute;
		top: 0;
		width: 100%;
		height: 100%;
		border-radius: 100%;
		filter: contrast(200%);
	}

	/* shadow */
	.sphere::before {
		background: radial-gradient(
				circle at 35% 22.5%,
				hsl(35, 90%, 0%, 0),
				hsl(35, 90%, 5%)
			),
			url(https://grainy-gradients.vercel.app/noise.svg);
		mix-blend-mode: multiply;
	}
	/* highlight. */
	.sphere::after {
		background: radial-gradient(
				circle at 10% 0%,
				color-mix(in hsl, var(--color-primary), white),
				var(--color-primary)
			),
			url(https://grainy-gradients.vercel.app/noise.svg);
		mix-blend-mode: screen;
		opacity: 0.05;
	}
</style>
